using System;
using System.Collections.Generic;

namespace MindfulnessProgram
{
    public class ListingActivity : Activity
    {
        private List<string> _prompts = new List<string>
        {
            "Who are people that you appreciate?",
            "What are personal strengths of yours?",
            "Who are people that you have helped this week?",
            "When have you felt peace this month?",
            "Who are some of your personal heroes?"
        };

        public ListingActivity() : base("Listing Activity", 
            "This activity will help you reflect on the good things in your life by having you list as many things as you can in a certain area.")
        {}

        public void Run()
        {
            DisplayStartingMessage();

            // 1. Select and display a random prompt
            Random random = new Random();
            Console.WriteLine("\nList as many responses as you can to the following prompt:");
            Console.WriteLine($" --- {_prompts[random.Next(_prompts.Count)]} --- ");
            
            // 2. Give them a few seconds to think
            Console.Write("You may begin in: ");
            ShowCountDown(5);
            Console.WriteLine();

            // 3. Collect items until time runs out
            List<string> userItems = GetListFromUser();

            // 4. Show results
            Console.WriteLine($"You listed {userItems.Count} items!");

            DisplayEndingMessage();
        }

        private List<string> GetListFromUser()
        {
            List<string> items = new List<string>();
            DateTime endTime = DateTime.Now.AddSeconds(_duration);

            // This loop checks the time each time the user finishes typing an entry
            while (DateTime.Now < endTime)
            {
                Console.Write("> ");
                string input = Console.ReadLine();
                if (!string.IsNullOrEmpty(input))
                {
                    items.Add(input);
                }
            }
            return items;
        }
    }
}